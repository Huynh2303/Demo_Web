@model List<Demo_web_MVC.Models.ViewModel.Carts.CartItemViewModel>
@using System.Globalization

@{
    ViewData["Title"] = "Giỏ hàng";

    var culture = new CultureInfo("vi-VN");
    decimal totalAmount = Model != null ? Model.Sum(x => x.Price * x.Quantity) : 0;
    int totalQuantity = Model != null ? Model.Sum(x => x.Quantity) : 0;
}

<link rel="stylesheet" href="~/css/Cartitems.css" />

<div class="cart-page">
    <div class="cart-container">

        <div class="cart-header">
            <div class="cart-header__left">
                <span>Sản phẩm</span>
            </div>
            <div class="cart-header__right">
                <span>Đơn giá</span>
                <span>Số lượng</span>
                <span>Số tiền</span>
                <span>Thao tác</span>
            </div>
        </div>

        @if (Model == null || !Model.Any())
        {
            <div class="cart-empty">
                <div class="cart-empty__icon">🛒</div>
                <h3>Giỏ hàng của bạn đang trống</h3>
                <p>Hãy thêm sản phẩm để tiếp tục mua sắm.</p>
                <a href="@Url.Action("Index", "Product")" class="cart-empty__btn">Mua sắm ngay</a>
            </div>
        }
        else
        {
            <div class="cart-list">
                @foreach (var item in Model)
                {
                    var imagePath = !string.IsNullOrEmpty(item.ImageUrl)
                        ? Url.Content(item.ImageUrl)
                        : Url.Content("~/uploads/images/no-image.jpg");

                    var itemTotal = item.Price * item.Quantity;

                    <div class="cart-item" data-id="@item.Id">
                        <div class="cart-item__product">
                            <div class="cart-item__image-wrap">
                                <img src="@imagePath" alt="@item.ProductName" class="cart-item__image" />
                            </div>

                            <div class="cart-item__info">
                                <a href="#" class="cart-item__name">@item.ProductName</a>
                                <div class="cart-item__variant">
                                    Phân loại hàng:
                                    @if (!string.IsNullOrEmpty(item.Color))
                                    {
                                        <span>@item.Color</span>
                                    }
                                    @if (!string.IsNullOrEmpty(item.Size))
                                    {
                                        <span> - @item.Size</span>
                                    }
                                </div>
                                @if (!string.IsNullOrEmpty(item.Brand))
                                {
                                    <div class="cart-item__brand">Thương hiệu: @item.Brand</div>
                                }
                            </div>
                        </div>

                        <div class="cart-item__price">
                            <span class="item-price" data-price="@item.Price">@item.Price.ToString("c0", culture)</span>
                        </div>

                        <div class="cart-item__quantity">
                            <div class="quantity-box">
                                <button type="button" class="qty-btn" onclick="updateQuantity(@item.Id, -1)">-</button>
                                <input type="text" value="@item.Quantity" id="qty-input-@item.Id" readonly class="qty-input" />
                                <button type="button" class="qty-btn" onclick="updateQuantity(@item.Id, 1)">+</button>
                            </div>
                        </div>

                        <div class="cart-item__total">
                            <span id="itemTotal-@item.Id" class="item-total" data-total="@itemTotal">@itemTotal.ToString("c0", culture)</span>
                        </div>
                        <!--xóa-->
                        <div class="cart-item__action">
                            <a href="@Url.Action("RemoveItem", "Cart" ,new {cartItemId=item.Id})" class="delete-link">Xóa</a>
                        </div>
                    </div>
                }
            </div>

            @*  <div class="cart-footer">
                <div class="cart-footer__left">
                    <span>Tổng số lượng: <strong id="totalQuantity">@totalQuantity</strong></span>
                </div>

                <div class="cart-footer__right">
                    <div class="cart-summary">
                        <span>Tổng thanh toán:</span>
                        <strong class="cart-summary-total" id="totalAmount">
                            @totalAmount.ToString("c0", culture)
                        </strong>
                    </div>
                </div>
            </div> *@
            <div class="cart-footer">
                <div class="cart-footer__left">
                    <label class="cart-footer__select-all">
                        <input type="checkbox" id="check-all-bottom" class="cart-checkbox" />
                        <span>Chọn tất cả (@Model.Count)</span>
                    </label>
                </div>

                <div class="cart-footer__right">
                    <div class="cart-summary">
                        <div class="cart-summary__quantity">
                            Đã chọn: <strong id="selectedQuantity">0</strong> sản phẩm
                        </div>
                        <div class="cart-summary__amount">
                            Tổng thanh toán:
                            <strong class="cart-summary-total" id="selectedAmount">0 ₫</strong>
                        </div>
                    </div>

                    <a href="#" class="checkout-btn">Mua hàng</a>
                </div>
            </div>
        }
    </div>
</div>

