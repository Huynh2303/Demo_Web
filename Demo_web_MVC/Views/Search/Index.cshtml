@model Demo_web_MVC.Models.ViewModel.Search.SearchViewModel
<!DOCTYPE html>

<html class="light" lang="vi">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;900&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
          darkMode: "class",
          theme: {
            extend: {
              "colors": {
                      "on-primary-container": "#003e58",
                      "on-secondary-fixed": "#1a1c1c",
                      "surface-bright": "#f5faff",
                      "on-tertiary-fixed": "#2d1600",
                      "primary": "#00658d",
                      "surface-container-highest": "#dee3e8",
                      "on-secondary-container": "#616363",
                      "inverse-on-surface": "#ecf1f7",
                      "secondary-fixed": "#e2e2e2",
                      "on-secondary": "#ffffff",
                      "on-primary-fixed-variant": "#004c6b",
                      "on-primary-fixed": "#001e2d",
                      "on-tertiary-fixed-variant": "#6b3b00",
                      "error-container": "#ffdad6",
                      "outline": "#6e7881",
                      "on-surface": "#171c20",
                      "on-tertiary": "#ffffff",
                      "surface-variant": "#dee3e8",
                      "on-primary": "#ffffff",
                      "surface-container-lowest": "#ffffff",
                      "primary-fixed": "#c6e7ff",
                      "tertiary-fixed": "#ffdcc0",
                      "surface-tint": "#00658d",
                      "surface": "#f5faff",
                      "background": "#f5faff",
                      "tertiary-fixed-dim": "#ffb876",
                      "on-secondary-fixed-variant": "#454747",
                      "secondary-container": "#dfe0e0",
                      "secondary": "#5d5f5f",
                      "on-surface-variant": "#3e4850",
                      "tertiary-container": "#ea8c21",
                      "on-background": "#171c20",
                      "surface-dim": "#d6dae0",
                      "on-error": "#ffffff",
                      "inverse-primary": "#82cfff",
                      "surface-container-high": "#e4e9ee",
                      "on-tertiary-container": "#572f00",
                      "surface-container-low": "#eff4fa",
                      "inverse-surface": "#2c3135",
                      "tertiary": "#8d4f00",
                      "outline-variant": "#bdc8d1",
                      "primary-container": "#00aeef",
                      "error": "#ba1a1a",
                      "secondary-fixed-dim": "#c6c6c7",
                      "primary-fixed-dim": "#82cfff",
                      "on-error-container": "#93000a",
                      "surface-container": "#eaeef4"
              },
              "borderRadius": {
                      "DEFAULT": "0.25rem",
                      "lg": "0.5rem",
                      "xl": "0.75rem",
                      "full": "9999px"
              },
              "spacing": {
                      "xl": "48px",
                      "container-max": "1200px",
                      "xs": "4px",
                      "sm": "8px",
                      "unit": "4px",
                      "lg": "24px",
                      "gutter": "16px",
                      "md": "16px"
              },
              "fontFamily": {
                      "display-lg": ["Be Vietnam Pro"],
                      "body-base": ["Be Vietnam Pro"],
                      "label-bold": ["Be Vietnam Pro"],
                      "body-sm": ["Be Vietnam Pro"],
                      "price-lg": ["Be Vietnam Pro"],
                      "headline-md": ["Be Vietnam Pro"]
              },
              "fontSize": {
                      "display-lg": ["32px", {"lineHeight": "1.2", "fontWeight": "700"}],
                      "body-base": ["16px", {"lineHeight": "1.5", "fontWeight": "400"}],
                      "label-bold": ["12px", {"lineHeight": "1.2", "letterSpacing": "0.02em", "fontWeight": "700"}],
                      "body-sm": ["14px", {"lineHeight": "1.5", "fontWeight": "400"}],
                      "price-lg": ["24px", {"lineHeight": "1", "fontWeight": "700"}],
                      "headline-md": ["20px", {"lineHeight": "1.4", "fontWeight": "600"}]
              }
            },
          },
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .line-clamp-2 {
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }
    </style>
</head>
<body class="bg-background font-body-base text-on-background min-h-screen flex flex-col">
    
    <main class="mt-24 mb-xl max-w-[1200px] mx-auto px-6 w-full flex-grow">
       
        <!-- Title Section -->
        <div class="mb-xl">
            <h1 class="font-display-lg text-display-lg text-on-surface mb-2">Kết quả tìm kiếm cho: '<span class="text-primary-container">@Model.SearchQuery</span>'</h1>
            <p class="font-body-base text-on-surface-variant">Tìm thấy @Model.PagingInfo!.TotalItems sản phẩm</p>
        </div>
        <!-- Sorting Bar -->
        <div class="bg-surface-container-low p-4 rounded-lg mb-gutter flex flex-col md:flex-row md:items-center justify-between gap-4">
            <div class="flex items-center gap-4">
                <span class="font-label-bold text-label-bold text-on-surface-variant">Sắp xếp theo:</span>
                <div class="flex flex-wrap gap-2">
                    <button class="px-4 py-2 bg-primary-container text-on-primary font-label-bold text-label-bold rounded-lg shadow-sm">Phổ biến</button>
                    <button class="px-4 py-2 bg-white text-on-surface font-label-bold text-label-bold rounded-lg hover:bg-gray-50 transition-colors border border-gray-100">Mới nhất</button>
                    <button class="px-4 py-2 bg-white text-on-surface font-label-bold text-label-bold rounded-lg hover:bg-gray-50 transition-colors border border-gray-100">Bán chạy</button>
                    <div class="relative group">
                        <button class="px-4 py-2 bg-white text-on-surface font-label-bold text-label-bold rounded-lg hover:bg-gray-50 transition-colors border border-gray-100 flex items-center gap-2">
                            Giá
                            <span class="material-symbols-outlined text-sm">expand_more</span>
                        </button>
                    </div>
                </div>
            </div>
            
        </div>
        <!-- Product Grid -->
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-gutter">
            <!-- Product Card Loop Simulation -->
            <partial name="_Product" model="Model.ProductVMResults" />
            
           
        </div>
        <!-- Empty State (Hidden by default unless results are zero) -->
        <div class="hidden flex-col items-center justify-center py-24 text-center">
            <span class="material-symbols-outlined text-7xl text-gray-300 mb-4">search_off</span>
            <h2 class="text-headline-md font-headline-md text-on-surface mb-2">Không tìm thấy kết quả</h2>
            <p class="text-body-base text-on-surface-variant max-w-md mx-auto">Vui lòng kiểm tra lại chính tả hoặc thử sử dụng những từ khóa khác tổng quát hơn.</p>
            <button class="mt-6 px-8 py-3 bg-primary-container text-on-primary font-label-bold rounded-lg shadow-lg active:scale-95 transition-all">Quay lại trang chủ</button>
        </div>
        <!-- Pagination -->
        @* <div class="mt-xl flex justify-center items-center gap-2">
            <button class="w-10 h-10 flex items-center justify-center bg-white border border-gray-200 rounded-lg text-gray-400 cursor-not-allowed">
                <span class="material-symbols-outlined">chevron_left</span>
            </button>
            <button class="w-10 h-10 flex items-center justify-center bg-primary-container text-on-primary font-label-bold rounded-lg shadow-md">1</button>
            <button class="w-10 h-10 flex items-center justify-center bg-white border border-gray-200 text-on-surface font-label-bold rounded-lg hover:border-primary-container hover:text-primary-container transition-colors">2</button>
            <button class="w-10 h-10 flex items-center justify-center bg-white border border-gray-200 text-on-surface font-label-bold rounded-lg hover:border-primary-container hover:text-primary-container transition-colors">3</button>
            <span class="px-2 text-on-surface-variant">...</span>
            <button class="w-10 h-10 flex items-center justify-center bg-white border border-gray-200 text-on-surface font-label-bold rounded-lg hover:border-primary-container hover:text-primary-container transition-colors">5</button>
            <button class="w-10 h-10 flex items-center justify-center bg-white border border-gray-200 rounded-lg text-on-surface hover:border-primary-container hover:text-primary-container transition-colors">
                <span class="material-symbols-outlined">chevron_right</span>
            </button>
        </div> *@
        @if(Model.PagingInfo!.TotalPages >1){

            <div class="mt-xl flex justify-center items-center gap-2">
                @if (Model.PagingInfo!.CurrentPage > 1)
                {
                    <!-- Trang trước (Previous) -->
                    <a href="@Url.Action("Index", "Search", new { searchQuery = Model.SearchQuery, page = Model.PagingInfo.CurrentPage - 1 })"
                       class="w-10 h-10 flex items-center justify-center bg-white border border-gray-200 rounded-lg text-gray-400 cursor-pointer">
                        <span class="material-symbols-outlined">chevron_left</span>
                    </a>
                }
                else
                {
                    <!-- Trang trước bị khóa -->
                    <button class="w-10 h-10 flex items-center justify-center bg-white border border-gray-200 rounded-lg text-gray-400 cursor-not-allowed">
                        <span class="material-symbols-outlined">chevron_left</span>
                    </button>
                }

                <!-- Các số trang (1, 2, 3, ...) -->
                @for (int i = 1; i <= Model.PagingInfo.TotalPages && i <= 5; i++)  
                {
                    <a href="@Url.Action("Index", "Search", new { searchQuery = Model.SearchQuery, page = i })"
                       class="w-10 h-10 flex items-center justify-center @(i == Model.PagingInfo.CurrentPage ? "bg-primary-container text-on-primary font-label-bold rounded-lg shadow-md" : "bg-white border border-gray-200 text-on-surface font-label-bold rounded-lg hover:border-primary-container hover:text-primary-container transition-colors")">
                        @i
                    </a>
                }

                <!-- Dấu "..." nếu có nhiều trang hơn 5 -->
                @if (Model.PagingInfo.TotalPages > 5 && Model.PagingInfo.CurrentPage < Model.PagingInfo.TotalPages - 2)
                {
                    <span class="px-2 text-on-surface-variant">...</span>
                }

                <!-- Các trang gần cuối -->
                @for (int i = Model.PagingInfo.TotalPages - 2; i <= Model.PagingInfo.TotalPages && i > 5; i++)  
                {
                    <a href="@Url.Action("Index", "Search", new { searchQuery = Model.SearchQuery, page = i })"
                       class="w-10 h-10 flex items-center justify-center @(i == Model.PagingInfo.CurrentPage ? "bg-primary-container text-on-primary font-label-bold rounded-lg shadow-md" : "bg-white border border-gray-200 text-on-surface font-label-bold rounded-lg hover:border-primary-container hover:text-primary-container transition-colors")">
                        @i
                    </a>
                }

                <!-- Trang cuối -->
                @if (Model.PagingInfo.CurrentPage < Model.PagingInfo.TotalPages)
                {
                    <a href="@Url.Action("Index", "Search", new { searchQuery = Model.SearchQuery, page = Model.PagingInfo.CurrentPage + 1 })"
                       class="w-10 h-10 flex items-center justify-center bg-white border border-gray-200 rounded-lg text-on-surface hover:border-primary-container hover:text-primary-container transition-colors">
                        <span class="material-symbols-outlined">chevron_right</span>
                    </a>
                }
                else
                {
                    <!-- Trang cuối bị khóa -->
                    <button class="w-10 h-10 flex items-center justify-center bg-white border border-gray-200 rounded-lg text-on-surface cursor-not-allowed">
                        <span class="material-symbols-outlined">chevron_right</span>
                    </button>
                }
            </div>
        }
    </main>
   
</body>
</html>