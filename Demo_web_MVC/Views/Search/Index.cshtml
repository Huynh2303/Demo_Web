@using Demo_web_MVC.Models.ViewModel.Product
@model Demo_web_MVC.Models.ViewModel.Search.SearchViewModel

<h2>Search Results</h2>

<!-- Form tìm kiếm -->
<form asp-controller="Search" asp-action="Search" method="get" class="shop-search">
    <input type="text" name="searchQuery"  placeholder="Tìm kiếm sản phẩm..." />
    <button type="submit">Tìm kiếm</button>
</form>

<hr />
@if (Model != null)
{
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger">
            <strong>Error:</strong> @Model.ErrorMessage
        </div>
    }
    else
    {
        <h3>Results for "@Model.SearchQuery":</h3>
        <p>Total results: @Model.TotalResults</p>

        <table class="table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Product Name</th>
                    <th>Description</th>
                    <th>Brand</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.ProductVMResults ?? new List<ProductViewModel>())
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.Name</td>
                        <td>@item.Description</td>
                        <td>@item.Brand</td>
                    </tr>
                }
            </tbody>
        </table>
    }
}
else
{
    <div class="alert alert-danger">Model is null.</div>
}