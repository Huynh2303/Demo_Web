
@{
    var title = ViewData["Title"] ?? "Demo_web_MVC";
    var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var action = ViewContext.RouteData.Values["action"]?.ToString() ?? "";

    var isShopPage =
        //controller.Equals("Home", StringComparison.OrdinalIgnoreCase) ||
        controller.Equals("Product", StringComparison.OrdinalIgnoreCase) ||
        controller.Equals("Cart", StringComparison.OrdinalIgnoreCase) ||
        controller.Equals("Adress", StringComparison.OrdinalIgnoreCase);

    var keyword = ViewBag.Keyword != null ? ViewBag.Keyword.ToString() : "";
    var cartCount = ViewBag.CartCount != null ? (int)ViewBag.CartCount : 0;
    
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Demo_web_MVC.styles.css" asp-append-version="true" />
    @RenderSection("Styles", required: false)
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>ASP.NET Commerce - Modern E-commerce</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@100;400;500;600;700;900&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet" />
    <script src="~/js/tailwind-config.js"></script>
    <style>
        .no-scrollbar::-webkit-scrollbar {
            display: none;
        }

        .no-scrollbar {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }

        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
    </style>
</head>
<body class="@(isShopPage ? "shop-layout-body" : "")">

    @if (isShopPage)
    {
        <!-- Header riêng cho khu shop -->
        <header class="bg-white/90 dark:bg-slate-900/90 backdrop-blur-md sticky top-0 z-50 border-b border-slate-200 dark:border-slate-800 shadow-lg shadow-black/5">
            <div class="flex flex-col w-full max-w-7xl mx-auto px-4 md:px-8 py-3">
                <div class="flex items-center justify-between gap-gutter">
                    <!-- Brand -->
                    <a class="text-2xl font-black text-sky-500 dark:text-sky-400 shrink-0" href="/">ASP.NET Commerce</a>
                    <!-- Search Bar -->
                    
                        <div class="hidden md:flex flex-1 max-w-2xl px-gutter">
                            <div class="relative w-full group">
                                <form asp-controller="Search" asp-action="Index" method="get">
                                    <input name="searchQuery" class="w-full bg-surface-container-low border-outline-variant rounded-lg py-2 pl-10 pr-4 focus:ring-2 focus:ring-primary-container focus:border-transparent transition-all outline-none" placeholder="Search products..." type="text" />
                                    <button class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline">search</button>
                                </form>
                            </div>
                        </div>
                    
                    
                    <!-- Actions -->
                    <div class="flex items-center gap-sm md:gap-lg">
                        <form asp-controller="Cart" asp-action="Index"  method="post">
                            <button class="p-2 text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-md transition-all active:scale-90 relative">
                                <span class="material-symbols-outlined" data-icon="shopping_cart">shopping_cart</span>
                                <span class="absolute top-1 right-1 w-4 h-4 bg-primary-container text-white text-[10px] flex items-center justify-center rounded-full">@cartCount</span>
                            </button>
                        </form>
                        @if (!User.Identity!.IsAuthenticated)
                        {
                            <form asp-controller="User" asp-action="Login" method="get">
                                <button class="p-2 text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-md transition-all active:scale-90">

                                    <span class="ml-2">Đăng nhập</span>
                                </button>
                            </form>
                        }
                        
                        <button class="p-2 text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-md transition-all active:scale-90">
                            <span class="material-symbols-outlined" data-icon="person">person</span>
                        </button>
                    </div>
                </div>
                <!-- Navigation Links (Desktop) -->
                <nav class="hidden md:flex items-center gap-lg mt-3">
                    <a class="font-be-vietnam-pro text-sm font-medium tracking-tight text-sky-500 border-b-2 border-sky-500 pb-1 transition-all" href="#">Electronics</a>
                    <a class="font-be-vietnam-pro text-sm font-medium tracking-tight text-slate-600 dark:text-slate-400 hover:text-sky-500 transition-all" href="#">Fashion</a>
                    <a class="font-be-vietnam-pro text-sm font-medium tracking-tight text-slate-600 dark:text-slate-400 hover:text-sky-500 transition-all" href="#">Home</a>
                    <a class="font-be-vietnam-pro text-sm font-medium tracking-tight text-slate-600 dark:text-slate-400 hover:text-sky-500 transition-all" href="#">Beauty</a>
                    <a class="font-be-vietnam-pro text-sm font-medium tracking-tight text-slate-600 dark:text-slate-400 hover:text-sky-500 transition-all" href="#">Toys</a>
                    <a class="font-be-vietnam-pro text-sm font-medium tracking-tight text-slate-600 dark:text-slate-400 hover:text-sky-500 transition-all" href="#">Sports</a>
                </nav>
            </div>
        </header>
    }
    else
    {
        <!-- Navbar mặc định cho trang không phải shop -->
        <header>
            <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
                <div class="container-fluid">
                    @* <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Demo_web_MVC</a> *@
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                            aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>

                    <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                        <ul class="navbar-nav flex-grow-1">
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Roles" asp-action="UpdateRole">UpdateRole</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                            </li>
                        </ul>

                        <partial name="_LoginPartial" />
                        <partial name="_MenuManagePartial" />
                    </div>
                </div>
            </nav>
        </header>
    }

    @if (isShopPage)
    {
        <main class="shop-main">
            @RenderBody()
        </main>

        <footer class="bg-slate-50 dark:bg-slate-950 w-full mt-auto border-t border-slate-200 dark:border-slate-800">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-8 max-w-7xl mx-auto px-8 py-12">
                <!-- Brand Column -->
                <div class="flex flex-col gap-4">
                    <span class="text-xl font-bold text-slate-900 dark:white">ASP.NET Commerce</span>
                    <p class="text-slate-500 dark:text-slate-400 text-body-sm leading-relaxed">Your premium destination for the latest in technology, lifestyle, and modern essentials. Designed for the tech-savvy generation.</p>
                    <div class="flex gap-4">
                        <a class="text-slate-400 hover:text-sky-500 transition-colors" href="#"><span class="material-symbols-outlined">public</span></a>
                        <a class="text-slate-400 hover:text-sky-500 transition-colors" href="#"><span class="material-symbols-outlined">hub</span></a>
                        <a class="text-slate-400 hover:text-sky-500 transition-colors" href="#"><span class="material-symbols-outlined">chat</span></a>
                    </div>
                </div>
                <!-- Links Column 1 -->
                <div class="flex flex-col gap-4">
                    <span class="text-sky-500 dark:text-sky-400 font-label-bold text-label-bold uppercase">Customer Service</span>
                    <nav class="flex flex-col gap-2">
                        <a class="text-slate-500 dark:text-slate-400 hover:text-sky-500 hover:underline transition-colors text-sm" href="#">Contact Us</a>
                        <a class="text-slate-500 dark:text-slate-400 hover:text-sky-500 hover:underline transition-colors text-sm" href="#">Shipping Info</a>
                        <a class="text-slate-500 dark:text-slate-400 hover:text-sky-500 hover:underline transition-colors text-sm" href="#">Returns</a>
                        <a class="text-slate-500 dark:text-slate-400 hover:text-sky-500 hover:underline transition-colors text-sm" href="#">Help Center</a>
                    </nav>
                </div>
                <!-- Links Column 2 -->
                <div class="flex flex-col gap-4">
                    <span class="text-sky-500 dark:text-sky-400 font-label-bold text-label-bold uppercase">Company</span>
                    <nav class="flex flex-col gap-2">
                        <a class="text-slate-500 dark:text-slate-400 hover:text-sky-500 hover:underline transition-colors text-sm" href="#">About Us</a>
                        <a class="text-slate-500 dark:text-slate-400 hover:text-sky-500 hover:underline transition-colors text-sm" href="#">Privacy Policy</a>
                        <a class="text-slate-500 dark:text-slate-400 hover:text-sky-500 hover:underline transition-colors text-sm" href="#">Terms of Service</a>
                        <a class="text-slate-500 dark:text-slate-400 hover:text-sky-500 hover:underline transition-colors text-sm" href="#">Careers</a>
                    </nav>
                </div>
                <!-- Contact Column -->
                <div class="flex flex-col gap-4">
                    <span class="text-sky-500 dark:text-sky-400 font-label-bold text-label-bold uppercase">Contact Information</span>
                    <div class="flex flex-col gap-3">
                        <div class="flex items-center gap-2 text-slate-500 dark:text-slate-400 text-sm">
                            <span class="material-symbols-outlined text-sky-500">location_on</span>
                            <span>123 Tech Avenue, Silicon Valley, CA</span>
                        </div>
                        <div class="flex items-center gap-2 text-slate-500 dark:text-slate-400 text-sm">
                            <span class="material-symbols-outlined text-sky-500">mail</span>
                            <span>support@aspnetcommerce.com</span>
                        </div>
                        <div class="flex items-center gap-2 text-slate-500 dark:text-slate-400 text-sm">
                            <span class="material-symbols-outlined text-sky-500">call</span>
                            <span>+1 (800) 123-4567</span>
                        </div>
                    </div>
                </div>
            </div>
            
        </footer>
    }
    else
    {
        <div class="container">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>

        <footer class="bg-slate-50 dark:bg-slate-950 w-full mt-auto border-t border-slate-200 dark:border-slate-800">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-8 max-w-7xl mx-auto px-8 py-12">
                <!-- Brand Column -->
                <div class="flex flex-col gap-4">
                    <span class="text-xl font-bold text-slate-900 dark:white">ASP.NET Commerce</span>
                    <p class="text-slate-500 dark:text-slate-400 text-body-sm leading-relaxed">Your premium destination for the latest in technology, lifestyle, and modern essentials. Designed for the tech-savvy generation.</p>
                    <div class="flex gap-4">
                        <a class="text-slate-400 hover:text-sky-500 transition-colors" href="#"><span class="material-symbols-outlined">public</span></a>
                        <a class="text-slate-400 hover:text-sky-500 transition-colors" href="#"><span class="material-symbols-outlined">hub</span></a>
                        <a class="text-slate-400 hover:text-sky-500 transition-colors" href="#"><span class="material-symbols-outlined">chat</span></a>
                    </div>
                </div>
                <!-- Links Column 1 -->
                <div class="flex flex-col gap-4">
                    <span class="text-sky-500 dark:text-sky-400 font-label-bold text-label-bold uppercase">Customer Service</span>
                    <nav class="flex flex-col gap-2">
                        <a class="text-slate-500 dark:text-slate-400 hover:text-sky-500 hover:underline transition-colors text-sm" href="#">Contact Us</a>
                        <a class="text-slate-500 dark:text-slate-400 hover:text-sky-500 hover:underline transition-colors text-sm" href="#">Shipping Info</a>
                        <a class="text-slate-500 dark:text-slate-400 hover:text-sky-500 hover:underline transition-colors text-sm" href="#">Returns</a>
                        <a class="text-slate-500 dark:text-slate-400 hover:text-sky-500 hover:underline transition-colors text-sm" href="#">Help Center</a>
                    </nav>
                </div>
                <!-- Links Column 2 -->
                <div class="flex flex-col gap-4">
                    <span class="text-sky-500 dark:text-sky-400 font-label-bold text-label-bold uppercase">Company</span>
                    <nav class="flex flex-col gap-2">
                        <a class="text-slate-500 dark:text-slate-400 hover:text-sky-500 hover:underline transition-colors text-sm" href="#">About Us</a>
                        <a class="text-slate-500 dark:text-slate-400 hover:text-sky-500 hover:underline transition-colors text-sm" href="#">Privacy Policy</a>
                        <a class="text-slate-500 dark:text-slate-400 hover:text-sky-500 hover:underline transition-colors text-sm" href="#">Terms of Service</a>
                        <a class="text-slate-500 dark:text-slate-400 hover:text-sky-500 hover:underline transition-colors text-sm" href="#">Careers</a>
                    </nav>
                </div>
                <!-- Contact Column -->
                <div class="flex flex-col gap-4">
                    <span class="text-sky-500 dark:text-sky-400 font-label-bold text-label-bold uppercase">Contact Information</span>
                    <div class="flex flex-col gap-3">
                        <div class="flex items-center gap-2 text-slate-500 dark:text-slate-400 text-sm">
                            <span class="material-symbols-outlined text-sky-500">location_on</span>
                            <span>123 Tech Avenue, Silicon Valley, CA</span>
                        </div>
                        <div class="flex items-center gap-2 text-slate-500 dark:text-slate-400 text-sm">
                            <span class="material-symbols-outlined text-sky-500">mail</span>
                            <span>support@aspnetcommerce.com</span>
                        </div>
                        <div class="flex items-center gap-2 text-slate-500 dark:text-slate-400 text-sm">
                            <span class="material-symbols-outlined text-sky-500">call</span>
                            <span>+1 (800) 123-4567</span>
                        </div>
                    </div>
                </div>
            </div>
            
        </footer>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>