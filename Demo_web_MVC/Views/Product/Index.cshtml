@model List<Demo_web_MVC.Models.ViewModel.Product.ProductViewModel>
@using System.Globalization
@using System.Linq
@using Demo_web_MVC.Models.ViewModel.Product
@{
    ViewData["Title"] = "Trang chủ";

    var currentPage = ViewBag.CurrentPage != null ? (int)ViewBag.CurrentPage : 1;
    var totalPages = ViewBag.TotalPages != null ? (int)ViewBag.TotalPages : 1;
    var keyword = ViewBag.Keyword != null ? ViewBag.Keyword.ToString() : "";
    var cartCount = ViewBag.CartCount != null ? (int)ViewBag.CartCount : 0;
}

@section Styles {
    <link rel="stylesheet" href="~/css/home.css" />
}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<div class="home-page">
    

    <main class="container main-content">
        <!-- Banner -->
        <section class="hero-banner">
            <div class="hero-banner__content">
                <span class="hero-banner__tag">Flash Sale</span>
                <h1 class="hero-banner__title">Mua sắm trẻ trung, bắt trend và dễ lướt</h1>
                <p class="hero-banner__desc">
                    Khám phá những sản phẩm nổi bật với giao diện hiện đại, gọn gàng, dễ xem như feed mua sắm.
                </p>

                <div class="hero-banner__actions">
                    <a href="@Url.Action("Index", "Product")" class="hero-btn hero-btn--primary">Mua ngay</a>
                    <a href="#product-list" class="hero-btn hero-btn--secondary">Xem sản phẩm</a>
                </div>
            </div>

            <div class="hero-banner__image-box">
                <img src="@Url.Content("~/uploads/images/banner-home.jpg")" alt="Banner trang chủ" class="hero-banner__image" />
            </div>
        </section>

        <!-- Product section -->
        <section class="product-section" id="product-list">
            <div class="section-heading">
                <div>
                    <h2>Sản phẩm nổi bật</h2>
                    <p>Danh sách sản phẩm đang được hiển thị trên trang chủ</p>
                </div>

                <div class="section-heading__meta">
                    @(Model != null ? Model.Count : 0) sản phẩm
                </div>
            </div>

            <div class="product-grid">
                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        var firstImage = item.imageUrl?.FirstOrDefault(x => !string.IsNullOrWhiteSpace(x));
                        var imagePath = !string.IsNullOrWhiteSpace(firstImage)
                            ? Url.Content(firstImage)
                            : Url.Content("~/uploads/images/no-image.jpg");

                        var price = (item.Variants != null && item.Variants.Any())
                            ? item.Variants.Min(v => v.Price)
                            : 0m;

                        var stock = (item.Variants != null && item.Variants.Any())
                            ? item.Variants.Min(v=>v.Stock) : 0m;

                        <article class="product-card">
                            <div class="product-card__badge">Sale</div>

                            <a href="@Url.Action("Details", "Product", new { id = item.Id })" class="product-card__link">
                                <div class="product-card__image-wrap">
                                    <img src="@imagePath"
                                         alt="@item.Name"
                                         class="product-card__image"
                                         onerror="this.onerror=null;this.src='@Url.Content("~/uploads/images/no-image.jpg")';" />
                                </div>

                                <div class="product-card__body">
                                    <h3 class="product-card__name" title="@item.Name">
                                        @item.Name
                                    </h3>

                                    <div class="product-card__rating">
                                        <span class="product-card__stars">★★★★★</span>
                                        <span class="product-card__score">4.9</span>
                                    </div>

                                    <div class="product-card__bottom">
                                        <div class="product-card__price">
                                                     
                                            @string.Format(new CultureInfo("vi-VN"), "{0:N0} ₫",price) 
                                            
                                        </div>
                                    </div>
                                    <!-- icon cart -->
                                    @* <div>
                                        <a href="@Url.Action("AddToCart", "Cart", new { userId = 1, variantId = item.VariantId, quantity = 1 })"class="cart-icon">
                                            <i class="bi bi-cart3"></i>
                                            <span class="cart-badge">3</span>
                                        </a>
                                    </div> *@
                                    <div>
                                        <a asp-action="DeleteConfirmed" asp-route-id="@item.Id">Delete</a>
                                    </div>
                                    <div>
                                        @if (stock > 0)
                                        {
                                            <span class="product-card__stock">Còn @stock sản phẩm</span>
                                        }
                                        else
                                        {
                                            <span class="product-card__stock product-card__stock--out">Hết hàng</span>
                                        }
                                    </div>
                                </div>
                            </a>
                        </article>
                    }
                }
                else
                {
                    <div class="empty-state">
                        <p>Chưa có sản phẩm để hiển thị.</p>
                    </div>
                }
            </div>

            <!-- Pagination -->
            <div class="pagination">
                <a href="@Url.Action("Index", "Home", new { page = currentPage - 1, keyword = keyword })"
                   class="pagination__btn @(currentPage <= 1 ? "disabled" : "")">
                    Previous
                </a>

                <span class="pagination__info">Trang @currentPage / @totalPages</span>

                <a href="@Url.Action("Index", "Home", new { page = currentPage + 1, keyword = keyword })"
                   class="pagination__btn @(currentPage >= totalPages ? "disabled" : "")">
                    Next
                </a>
            </div>
        </section>
    </main>
</div>
