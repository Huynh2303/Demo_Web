
@using System.Text.Json
@model Demo_web_MVC.Models.ViewModel.Product.ProductViewModel
<!DOCTYPE html>

<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@100;200;300;400;500;600;700;800;900&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "on-tertiary-fixed": "#2d1600",
                        "on-error": "#ffffff",
                        "inverse-surface": "#2c3135",
                        "surface-container-highest": "#dee3e8",
                        "on-tertiary-container": "#572f00",
                        "on-primary-container": "#003e58",
                        "primary": "#00658d",
                        "inverse-on-surface": "#ecf1f7",
                        "on-secondary": "#ffffff",
                        "surface-container-high": "#e4e9ee",
                        "on-surface-variant": "#3e4850",
                        "surface": "#f5faff",
                        "on-background": "#171c20",
                        "primary-fixed": "#c6e7ff",
                        "inverse-primary": "#82cfff",
                        "outline-variant": "#bdc8d1",
                        "surface-variant": "#dee3e8",
                        "on-primary": "#ffffff",
                        "surface-dim": "#d6dae0",
                        "on-tertiary": "#ffffff",
                        "surface-container": "#eaeef4",
                        "primary-container": "#00aeef",
                        "error": "#ba1a1a",
                        "secondary": "#5d5f5f",
                        "surface-tint": "#00658d",
                        "secondary-fixed-dim": "#c6c6c7",
                        "primary-fixed-dim": "#82cfff",
                        "tertiary-fixed-dim": "#ffb876",
                        "surface-container-lowest": "#ffffff",
                        "secondary-container": "#dfe0e0",
                        "on-surface": "#171c20",
                        "on-secondary-fixed-variant": "#454747",
                        "on-tertiary-fixed-variant": "#6b3b00",
                        "on-primary-fixed": "#001e2d",
                        "outline": "#6e7881",
                        "on-secondary-fixed": "#1a1c1c",
                        "on-secondary-container": "#616363",
                        "tertiary-container": "#ea8c21",
                        "surface-container-low": "#eff4fa",
                        "tertiary": "#8d4f00",
                        "secondary-fixed": "#e2e2e2",
                        "on-primary-fixed-variant": "#004c6b",
                        "on-error-container": "#93000a",
                        "tertiary-fixed": "#ffdcc0",
                        "surface-bright": "#f5faff",
                        "error-container": "#ffdad6",
                        "background": "#f5faff"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "full": "9999px"
                    },
                    "spacing": {
                        "xl": "48px",
                        "md": "16px",
                        "unit": "4px",
                        "sm": "8px",
                        "lg": "24px",
                        "gutter": "16px",
                        "container-max": "1200px",
                        "xs": "4px"
                    },
                    "fontFamily": {
                        "body-base": ["Be Vietnam Pro"],
                        "price-lg": ["Be Vietnam Pro"],
                        "label-bold": ["Be Vietnam Pro"],
                        "display-lg": ["Be Vietnam Pro"],
                        "body-sm": ["Be Vietnam Pro"],
                        "headline-md": ["Be Vietnam Pro"]
                    },
                    "fontSize": {
                        "body-base": ["16px", {"lineHeight": "1.5", "fontWeight": "400"}],
                        "price-lg": ["24px", {"lineHeight": "1", "fontWeight": "700"}],
                        "label-bold": ["12px", {"lineHeight": "1.2", "letterSpacing": "0.02em", "fontWeight": "700"}],
                        "display-lg": ["32px", {"lineHeight": "1.2", "fontWeight": "700"}],
                        "body-sm": ["14px", {"lineHeight": "1.5", "fontWeight": "400"}],
                        "headline-md": ["20px", {"lineHeight": "1.4", "fontWeight": "600"}]
                    }
                },
            },
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        .zoom-container:hover img {
            transform: scale(1.05);
        }

        .hide-scrollbar::-webkit-scrollbar {
            display: none;
        }

        .hide-scrollbar {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
    </style>
    @section Styles {
        <link rel="stylesheet" href="~/css/cart.css" />
        <style>
            .variant-chip.active {
                background-color: #c4c577;
                color: #fff;
                border-color: #c4c577;
            }

            .variant-chip.disabled {
                opacity: 0.5;
                cursor: not-allowed;
            }
        </style>
    }


</head>
<body class="bg-background font-body-base text-on-background">
    <!-- TopNavBar -->

    <main class="max-w-[1200px] mx-auto px-8 pt-24 pb-xl">
        <!-- Razor Integration Stub -->
        <!-- Breadcrumb -->
        <nav aria-label="Breadcrumb" class="flex mb-lg">
            <ol class="inline-flex items-center space-x-2 text-body-sm text-secondary">
                <li class="inline-flex items-center">
                    <a class="hover:text-primary transition-colors" href="/">Home</a>
                </li>
                <li>
                    <div class="flex items-center">
                        <span class="material-symbols-outlined text-xs mx-1">chevron_right</span>
                        <a class="hover:text-primary transition-colors" href="/electronics">Electronics</a>
                    </div>
                </li>
                <li>
                    <div class="flex items-center">
                        <span class="material-symbols-outlined text-xs mx-1">chevron_right</span>
                        <a class="hover:text-primary transition-colors" href="/electronics/headphones">Headphones</a>
                    </div>
                </li>
                <li>
                    <div class="flex items-center">
                        <span class="material-symbols-outlined text-xs mx-1">chevron_right</span>
                        <span class="text-on-background font-medium">Studio Pro Headphones</span>
                    </div>
                </li>
            </ol>
        </nav>
        <!-- Product Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-xl">
            <!-- Left Column: Gallery -->
            <div class="space-y-md">
                <div class="zoom-container overflow-hidden rounded-xl bg-surface-container-lowest shadow-[0px_4px_12px_rgba(0,0,0,0.05)] aspect-square border border-slate-100">
                   <img alt="Studio Pro Headphones"
                     class="w-full h-full object-cover transition-transform duration-500 ease-out"
                     src="@(Model?.imageUrl != null && Model.imageUrl.Any()
                         ? Url.Content(Model.imageUrl.First())
                         : Url.Content("~/uploads/images/no-image.jpg"))" />
                </div>
                <div class="flex gap-sm overflow-x-auto pb-2 hide-scrollbar">
                    @if(Model?.imageUrl != null && Model.imageUrl.Any())
                    {
                       @foreach (var img in Model!.imageUrl){ 
                        <div class="flex-shrink-0 w-24 h-24 rounded-lg border-2 border-primary-container overflow-hidden cursor-pointer">
                            <img alt="Thumbnail 1" class="w-full h-full object-cover" data-alt="close up of headphone ear cup showing premium leather texture and stitching detail" src="@img"/>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="flex-shrink-0 w-24 h-24 rounded-lg border-2 border-primary-container overflow-hidden cursor-pointer">
                            <img alt="Thumbnail 1" class="w-full h-full object-cover" data-alt="close up of headphone ear cup showing premium leather texture and stitching detail"  src="@Url.Content("~/uploads/images/no-image.jpg")"/>
                            </div>
                    }

                </div>
            </div>
            <!-- Right Column: Info -->
            <div class="flex flex-col">
                <h1 class="font-display-lg text-display-lg text-on-background mb-unit">@Model.Name</h1>
                <div class="flex items-center gap-2 mb-md">
                    <div class="flex text-tertiary-container">
                        <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span>
                        <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span>
                        <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span>
                        <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span>
                        <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star_half</span>
                    </div>
                    <span class="text-body-sm text-secondary">(128 Reviews)</span>
                </div>
                <div class="flex items-center gap-4 mb-lg">
                    <span class="font-price-lg text-price-lg text-on-background">@Model.Variants!.Min(v => v.Price)</span>
                    <span class="text-secondary line-through text-body-base">@((Model.Variants!.Min(v => v.Price)) * 0.8m)</span>
                    <span class="bg-primary-fixed text-on-primary-fixed text-label-bold px-2 py-1 rounded-full">-20%</span>
                </div>
                <p class="text-body-base text-on-surface-variant mb-lg leading-relaxed line-clamp-3">
                    @Model.Description
                </p>
                <form asp-controller="Cart" asp-action="AddToCart" method="post" id="addToCartForm">
                    <input type="hidden" name="variantId" id="selectedVariantId" />
                    <input type="hidden" name="quantity" id="hiddenQuantity" value="1" />
                <div class="space-y-lg border-t border-slate-100 pt-lg">
                    <!-- Size Selection -->
                    @if (Model.Variants!
                                        .Where(v => v.Size != null)
                                        .Select(v => v.Size)
                                        .Distinct().Any())
                    {
                        <div>
                            <span class="font-label-bold text-label-bold text-on-background block mb-sm">
                                Select Size
                            </span>
                            <div class="flex gap-2">
                                @foreach (var size in Model.Variants!
                                                            .Where(v => v.Size != null)
                                                            .Select(v => v.Size)
                                                            .Distinct())
                                {
                                    <label class="cursor-pointer">
                                        <input type="radio"
                                               name="size"
                                               value="@size"
                                               data-size="@size"
                                               class="peer hidden size-option"
                                               required />

                                        <span class="px-6 py-2 rounded-lg border border-gray-300 text-gray-600 font-semibold
                                         hover:border-blue-500 transition-all
                                         peer-checked:bg-blue-500
                                         peer-checked:text-white
                                         peer-checked:border-blue-500">
                                            @size
                                        </span>
                                    </label>
                                }

                            </div>
                        </div>
                    }

                    <!-- Color Selection -->
                    @if (Model.Variants!.Where(v => v.Color != null)
                                        .Select(v => v.Color).Distinct().Any())
                    {
                        <div>
                            <span class="font-label-bold text-label-bold text-on-background block mb-sm">Color</span>
                            <div class="flex gap-3">
                                @foreach (var color in Model.Variants!.Where(v => v.Color != null)
                                                            .Select(v => v.Color).Distinct())
                                {
                                    <label class="cursor-pointer">
                                        <input type="radio"
                                               name="color"
                                               value="@color"
                                               data-color="@color"
                                               class="peer hidden color-option"
                                               required />

                                        <span class="px-6 py-2 rounded-lg border border-gray-300 text-gray-600 font-semibold
                                                 hover:border-blue-500 transition-all
                                                 peer-checked:bg-blue-500
                                                 peer-checked:text-white
                                                 peer-checked:border-blue-500">
                                            @color
                                        </span>
                                    </label>
                                }

                            </div>
                        </div>
                    }

                    <!-- Quantity and Actions -->
                    <div class="flex flex-col gap-md pt-md">

                        <!-- Quantity -->
                        <div class="flex items-center gap-lg">
                            <div class="flex items-center border border-outline-variant rounded-lg bg-white h-12 px-2">

                                <button type="button"
                                        id="decreaseQty"
                                        class="w-8 h-8 flex items-center justify-center text-secondary hover:text-primary-container transition-colors">
                                    <span class="material-symbols-outlined text-lg">remove</span>
                                </button>

                                <input id="quantityInput"
                                       class="w-20 text-center border-none focus:ring-0 text-body-base font-bold bg-transparent"
                                       type="number"
                                       value="1"
                                       min="1" />

                                <button type="button"
                                        id="increaseQty"
                                        class="w-8 h-8 flex items-center justify-center text-secondary hover:text-primary-container transition-colors">
                                    <span class="material-symbols-outlined text-lg">add</span>
                                </button>

                            </div>
                        </div>

                        <!-- Hidden quantity submit -->
                        <input type="hidden" name="quantity" id="hiddenQuantity" value="1" />

                        <!-- Actions -->
                        <div class="flex flex-col sm:flex-row gap-md">
                             
                            <button type="submit"
                                    class="flex-1 bg-primary-container text-white font-label-bold py-4 rounded-lg shadow-sm hover:opacity-90 active:scale-[0.98] transition-all flex items-center justify-center gap-2">
                                <span class="material-symbols-outlined">shopping_cart</span>
                                Add to Cart
                            </button>
                            

                            <button type="button"
                                    class="flex-1 bg-white border-2 border-primary-container text-primary-container font-label-bold py-4 rounded-lg hover:bg-slate-50 active:scale-[0.98] transition-all">
                                Buy Now
                            </button>

                        </div>

                    </div>
                </div>
                </form>
            </div>
        </div>
        <!-- Tabs Section -->
        <section class="mt-xl">
            <div class="flex border-b border-slate-200 gap-xl mb-lg">
                <button class="pb-md font-label-bold text-label-bold text-primary-container border-b-2 border-primary-container uppercase tracking-wider">Product Description</button>
                
            </div>
            <div class="prose prose-slate max-w-none text-body-base text-on-surface-variant leading-loose">
                <p>@Model.Description</p>
                
            </div>
        </section>
        <!-- Customer Reviews -->
        <section class="mt-xl pt-xl border-t border-slate-200">
            <h2 class="font-headline-md text-headline-md mb-lg">Customer Reviews</h2>
            <div class="space-y-lg">
                <div class="p-lg bg-surface-container-low rounded-xl border border-slate-100">
                    <div class="flex justify-between items-start mb-md">
                        <div>
                            <span class="font-label-bold text-body-base block">Alex Morgan</span>
                            <div class="flex text-tertiary-container text-sm">
                                <span class="material-symbols-outlined text-[18px]" style="font-variation-settings: 'FILL' 1;">star</span>
                                <span class="material-symbols-outlined text-[18px]" style="font-variation-settings: 'FILL' 1;">star</span>
                                <span class="material-symbols-outlined text-[18px]" style="font-variation-settings: 'FILL' 1;">star</span>
                                <span class="material-symbols-outlined text-[18px]" style="font-variation-settings: 'FILL' 1;">star</span>
                                <span class="material-symbols-outlined text-[18px]" style="font-variation-settings: 'FILL' 1;">star</span>
                            </div>
                        </div>
                        <span class="text-body-sm text-secondary">2 days ago</span>
                    </div>
                    <p class="text-body-base text-on-surface-variant italic">"Best headphones I've owned. The battery life actually exceeds the advertised 40 hours. Noise cancellation is spooky quiet!"</p>
                </div>
                <div class="p-lg bg-surface-container-low rounded-xl border border-slate-100">
                    <div class="flex justify-between items-start mb-md">
                        <div>
                            <span class="font-label-bold text-body-base block">Sarah Chen</span>
                            <div class="flex text-tertiary-container text-sm">
                                <span class="material-symbols-outlined text-[18px]" style="font-variation-settings: 'FILL' 1;">star</span>
                                <span class="material-symbols-outlined text-[18px]" style="font-variation-settings: 'FILL' 1;">star</span>
                                <span class="material-symbols-outlined text-[18px]" style="font-variation-settings: 'FILL' 1;">star</span>
                                <span class="material-symbols-outlined text-[18px]" style="font-variation-settings: 'FILL' 1;">star</span>
                                <span class="material-symbols-outlined text-[18px]">star</span>
                            </div>
                        </div>
                        <span class="text-body-sm text-secondary">1 week ago</span>
                    </div>
                    <p class="text-body-base text-on-surface-variant italic">"Excellent sound quality. They are a bit heavy for long sessions, but the padding helps a lot."</p>
                </div>
            </div>
            <button class="mt-lg text-primary-container font-label-bold flex items-center gap-1 hover:underline underline-offset-4">
                See All 128 Reviews
                <span class="material-symbols-outlined text-sm">arrow_forward</span>
            </button>
        </section>
        <!-- Related Products -->
        <partial name="_RelatedProducts" model="Model.RelatedProducts" />
    </main>
    <!-- Footer -->
    <script>
    const variants = @Html.Raw(JsonSerializer.Serialize(Model.Variants!
        .Where(v => v != null)
        .Select(v => new {
            Id = v.Id,
            Color = v.Color != null ? v.Color.ToString() : "",
            Size = v.Size != null ? v.Size.ToString() : ""
        })
        .ToList()));

    let selectedColor = null;
    let selectedSize = null;

    const colorRadios = document.querySelectorAll('.color-option');
    const sizeRadios = document.querySelectorAll('.size-option');

    const selectedVariantInput = document.getElementById('selectedVariantId');
    const quantityInput = document.getElementById('quantityInput');
    const hiddenQuantity = document.getElementById('hiddenQuantity');
    const decreaseQty = document.getElementById('decreaseQty');
    const increaseQty = document.getElementById('increaseQty');
    const form = document.getElementById('addToCartForm');

    function normalize(value) {
        return (value || '').toString().trim().toLowerCase();
    }

    function updateVariantId() {
        const matchedVariant = variants.find(v =>
            normalize(v.Color) === normalize(selectedColor) &&
            normalize(v.Size) === normalize(selectedSize)
        );

        selectedVariantInput.value = matchedVariant ? matchedVariant.Id : '';
    }

    sizeRadios.forEach(radio => {
        radio.addEventListener('change', function () {
            selectedSize = this.dataset.size;
            updateVariantId();
        });
    });

    colorRadios.forEach(radio => {
        radio.addEventListener('change', function () {
            selectedColor = this.dataset.color;
            updateVariantId();
        });
    });

    function syncQuantity() {
        let qty = parseInt(quantityInput.value, 10);

        if (isNaN(qty) || qty < 1) {
            qty = 1;
        }

        quantityInput.value = qty;
        hiddenQuantity.value = qty;
    }

    quantityInput.addEventListener('input', syncQuantity);

    decreaseQty.addEventListener('click', function () {
        quantityInput.value = parseInt(quantityInput.value || 1) - 1;
        syncQuantity();
    });

    increaseQty.addEventListener('click', function () {
        quantityInput.value = parseInt(quantityInput.value || 1) + 1;
        syncQuantity();
    });

    form.addEventListener('submit', function (e) {
        syncQuantity();

        if (!selectedSize) {
            e.preventDefault();
            alert('Vui lòng chọn size');
            return;
        }

        if (!selectedColor) {
            e.preventDefault();
            alert('Vui lòng chọn màu');
            return;
        }

        if (!selectedVariantInput.value) {
            e.preventDefault();
            alert('Biến thể không hợp lệ');
            return;
        }
    });

    syncQuantity();
</script>
</body>
</html>